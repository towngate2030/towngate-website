# Public site URL (canonical + metadata). Set in Vercel Production.
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# WhatsApp: digits only, country code without + (default matches plan)
NEXT_PUBLIC_WHATSAPP_E164=966593053792

# Contact form → email (Resend). Optional: without RESEND_API_KEY, submissions are logged server-side only.
CONTACT_EMAIL=Towngate2030@gmail.com
RESEND_API_KEY=
# Must be a verified sender in Resend, e.g. TownGate <onboarding@resend.dev> for testing
RESEND_FROM=

# Sanity (content CMS)
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2025-02-19
# Optional: if dataset is private, add a read token on Vercel (Server only)
SANITY_API_READ_TOKEN=

# Admin login for /tg-cp-internal
ADMIN_USERNAME=townGateAdmin
ADMIN_PASSWORD=change-this-strong-password
# Generate a random base64url secret (example below) and keep it private
ADMIN_SESSION_SECRET=SAowGslt19V1m8MCrzDpMrq_3uw9boCxLBxEJNeeN98

