# Public site URL (canonical + metadata). Set in Vercel Production.
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# WhatsApp: digits only, country code without + (default matches plan)
NEXT_PUBLIC_WHATSAPP_E164=966593053792

# Contact form → email (Resend). Optional: without RESEND_API_KEY, submissions are logged server-side only.
CONTACT_EMAIL=Towngate2030@gmail.com
RESEND_API_KEY=
# Must be a verified sender in Resend (domain verification recommended)
RESEND_FROM=Town Gate <no-reply@towngate-eg.com>

# Sanity (content CMS)
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2025-02-19
# Optional: if dataset is private, add a read token on Vercel (Server only)
SANITY_API_READ_TOKEN=

# Server-only: Editor token for creating newsletter subscribers + marking issues sent (never expose to client)
SANITY_API_WRITE_TOKEN=

# Optional: long random secret so Sanity Studio can POST /api/newsletter/broadcast (Bearer). Match SANITY_STUDIO_NEWSLETTER_SEND_SECRET in Studio env.
NEWSLETTER_SEND_SECRET=

# Sanity Studio broadcast/send UI (required for in-Studio buttons): production origin, no trailing slash (duplicates NEXT_PUBLIC_SITE_URL is fine).
SANITY_STUDIO_APP_ORIGIN=https://your-domain.com
# Same value as NEWSLETTER_SEND_SECRET — enables in-Studio send. If unset, Studio opens /tg-cp-internal/newsletter instead.
SANITY_STUDIO_NEWSLETTER_SEND_SECRET=

# Admin login for /tg-cp-internal
ADMIN_USERNAME=townGateAdmin
ADMIN_PASSWORD=change-this-strong-password
# Generate a random base64url secret (example below) and keep it private
ADMIN_SESSION_SECRET=SAowGslt19V1m8MCrzDpMrq_3uw9boCxLBxEJNeeN98

# Optional: headless CMS later (Sanity)
# NEXT_PUBLIC_SANITY_PROJECT_ID=
# SANITY_API_READ_TOKEN=
