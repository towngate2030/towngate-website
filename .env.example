# Public site URL (canonical + metadata). Set in Vercel Production.
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# WhatsApp: digits only, country code without + (default matches plan)
NEXT_PUBLIC_WHATSAPP_E164=966593053792

# Contact form → email (Resend). Optional: without RESEND_API_KEY, submissions are logged server-side only.
CONTACT_EMAIL=Towngate2030@gmail.com
RESEND_API_KEY=
# Must be a verified sender in Resend, e.g. TownGate <onboarding@resend.dev> for testing
RESEND_FROM=

# Optional: headless CMS later (Sanity)
# NEXT_PUBLIC_SANITY_PROJECT_ID=
# SANITY_API_READ_TOKEN=
