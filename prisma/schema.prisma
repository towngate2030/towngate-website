// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model SiteSettings {
  id              Int      @id @default(1)
  heroBgUrl       String   @default("")
  heroTitleAr     String   @default("نصمّم أماكن تعيش فيها القصة.")
  heroTitleEn     String   @default("We craft places where stories live.")
  heroSubtitleAr  String   @default("مشاريع مختارة، جودة تنفيذ، وشراكة تبدأ من أول محادثة.")
  heroSubtitleEn  String   @default("Curated projects, refined delivery, and a partnership that starts with a conversation.")
  kickerAr        String   @default("كمبوند — العاصمة الإدارية")
  kickerEn        String   @default("Compound — New Capital")
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())
}

model ValueBox {
  id        String   @id @default(cuid())
  order     Int
  titleAr   String
  titleEn   String
  bodyAr    String
  bodyEn    String
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@unique([order])
}

model WhatsAppContact {
  id        String   @id @default(cuid())
  order     Int
  name      String
  e164      String   // digits only e.g. 966593053792
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@unique([order])
}

model Project {
  id          String   @id @default(cuid())
  slug        String   @unique
  featured    Boolean  @default(false)
  status      String   @default("available") // available | sold

  titleAr     String
  titleEn     String
  excerptAr   String
  excerptEn   String
  locationAr  String
  locationEn  String

  // Rich text JSON from TipTap (ProseMirror)
  bodyAr      Json
  bodyEn      Json

  // Media URLs (Cloudflare-hosted)
  imageUrls   String[] @default([])
  videoUrls   String[] @default([])

  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())
}
